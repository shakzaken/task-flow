WORKER_PORT=8001

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=task_flow
POSTGRES_USER=user
POSTGRES_PASSWORD=

RABBITMQ_URL=amqp://guest:guest@localhost:5672/
WORKER_CONSUMER_QUEUE=tasks.phase1
WORKER_MAX_CONCURRENCY=4
RABBITMQ_PREFETCH_COUNT=4

DB_POOL_SIZE=4
DB_MAX_OVERFLOW=2

EMAIL_PROVIDER_MODE=fake
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Task Flow

OUTPUT_STORAGE_PATH=outputs
WORKER_WORK_ROOT=/tmp/task-flow-worker

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=task-flow
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_USE_SSL=false
S3_FORCE_PATH_STYLE=true
S3_AUTO_CREATE_BUCKET=true

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
