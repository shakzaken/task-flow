APP_ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=

API_PORT=8000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=task_flow
POSTGRES_USER=yakir
POSTGRES_PASSWORD=

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/%2F
