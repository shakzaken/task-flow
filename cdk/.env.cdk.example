AWS_ACCOUNT=
AWS_REGION=eu-west-1
STACK_NAME=TaskFlowStack
APP_NAME=task-flow

API_IMAGE_REPOSITORY=task-flow-api
API_IMAGE_TAG=latest
WORKER_IMAGE_REPOSITORY=task-flow-worker
WORKER_IMAGE_TAG=latest

S3_BUCKET_NAME=task-flow-prod-artifacts

API_PORT=8000
WORKER_PORT=8001

POSTGRES_PORT=5432
POSTGRES_DB=task_flow
POSTGRES_USER=task_flow
POSTGRES_PASSWORD=

REDIS_PORT=6379

RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=
RABBITMQ_VHOST=%2F
RABBITMQ_QUEUE=tasks.phase1
RABBITMQ_PREFETCH_COUNT=4

WORKER_MAX_CONCURRENCY=4
DB_POOL_SIZE=4
DB_MAX_OVERFLOW=2

EMAIL_PROVIDER_MODE=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Task Flow

WORKER_WORK_ROOT=/tmp/task-flow-worker
OUTPUT_STORAGE_PATH=outputs

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
